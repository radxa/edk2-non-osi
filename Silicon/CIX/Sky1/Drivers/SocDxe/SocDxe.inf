  BaseMemoryLib
  DebugLib
  MemoryAllocationLib
  IoLib
  PcdLib
  UefiBootServicesTableLib
  UefiDriverEntryPoint
  UefiLib
  GpioLib
  PinMuxLib
  ShMemLib
  MailBoxLib

[Guids]

[Protocols]
  gCixSocInfoProtocolGuid
  gCixResetProtocolGuid
  gCixClockProtocolGuid

[Pcd]
  gCixTokenSpaceGuid.PcdSeHandoffInfoBaseAddr
  gArmTokenSpaceGuid.PcdSystemMemorySize

