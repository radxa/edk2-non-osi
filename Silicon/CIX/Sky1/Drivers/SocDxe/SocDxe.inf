[Defines]
  INF_VERSION                    = 0x0001001A
  BASE_NAME                      = SocDxe
  FILE_GUID                      = A4A011DA-89F9-462A-2806-2375CDD35609
  MODULE_TYPE                    = DXE_DRIVER
  VERSION_STRING                 = 1.0
  ENTRY_POINT                    = SocDxeEntryPoint

[Binaries.AARCH64]
  PE32|SocDxe.efi|*
  DXE_DEPEX|SocDxe.depex|*

[Packages]
