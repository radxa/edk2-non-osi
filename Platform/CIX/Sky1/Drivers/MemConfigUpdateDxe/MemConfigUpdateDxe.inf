  DxeServicesLib
  PcdLib
  IoLib
  BaseMemoryLib
  DebugLib
  UefiRuntimeServicesTableLib
  UefiBootServicesTableLib
  UefiDriverEntryPoint

[Protocols]
  gCixFirmwareUpdateProtocolGuid

[Guids]
  gPlatformSetupVariableGuid
  gSetupSaveVariableCallBackGuid

[Depex]
  TRUE
